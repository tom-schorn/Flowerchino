{% extends 'base.html.twig' %}

{% block title %}Generating {{ plant.canonicalName }} — Flowerchino{% endblock %}

{% block stylesheets %}
<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
body { font-family: system-ui, -apple-system, sans-serif; background: #f4f6f3; color: #1a1a1a; }
.page { max-width: 520px; margin: 0 auto; padding: 4rem 1rem; text-align: center; }

h1 { font-size: 1.5rem; font-weight: 700; color: #1a2e1a; margin-bottom: 0.4rem; }
h1 em { font-style: italic; }
.sub { color: #6b7280; font-size: 0.9rem; margin-bottom: 2.5rem; }

/* Progress bar */
.progress-wrap { background: #e5e7eb; border-radius: 99px; height: 6px; margin-bottom: 2rem; overflow: hidden; }
.progress-bar  { height: 100%; background: #1a2e1a; border-radius: 99px; width: 0%; transition: width 0.4s ease; }

/* Step list */
.steps { list-style: none; text-align: left; }
.step {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.45rem 0.6rem;
    border-radius: 8px;
    font-size: 0.85rem;
    color: #9ca3af;
    transition: all 0.2s;
}
.step.active  { background: #f0fdf4; color: #1a2e1a; font-weight: 600; }
.step.done    { color: #16a34a; }
.step .icon   { font-size: 1rem; width: 1.2rem; text-align: center; flex-shrink: 0; }
.step .label  { flex: 1; }

.current-label {
    margin-top: 1.5rem;
    font-size: 0.8rem;
    color: #9ca3af;
    min-height: 1.2em;
}
</style>
{% endblock %}

{% block body %}
<div class="page">
    <h1>Generating <em>{{ plant.canonicalName }}</em></h1>
    <p class="sub">Claude is researching each growth stage. This takes about 30 seconds.</p>

    <div class="progress-wrap">
        <div class="progress-bar" id="progressBar"></div>
    </div>

    <ul class="steps" id="stepList">
        <li class="step" id="step-meta">
            <span class="icon">🌿</span>
            <span class="label">Botanical data &amp; taxonomy</span>
        </li>
        <li class="step" id="step-hydro_germinating"><span class="icon">💧</span><span class="label">Hydroponic · Germinating</span></li>
        <li class="step" id="step-hydro_seedling">   <span class="icon">💧</span><span class="label">Hydroponic · Seedling</span></li>
        <li class="step" id="step-hydro_vegetative"> <span class="icon">💧</span><span class="label">Hydroponic · Vegetative</span></li>
        <li class="step" id="step-hydro_flowering">  <span class="icon">💧</span><span class="label">Hydroponic · Flowering</span></li>
        <li class="step" id="step-hydro_fruiting">   <span class="icon">💧</span><span class="label">Hydroponic · Fruiting</span></li>
        <li class="step" id="step-hydro_harvesting"> <span class="icon">💧</span><span class="label">Hydroponic · Harvesting</span></li>
        <li class="step" id="step-soil_germinating"> <span class="icon">🌱</span><span class="label">Soil · Germinating</span></li>
        <li class="step" id="step-soil_seedling">    <span class="icon">🌱</span><span class="label">Soil · Seedling</span></li>
        <li class="step" id="step-soil_vegetative">  <span class="icon">🌱</span><span class="label">Soil · Vegetative</span></li>
        <li class="step" id="step-soil_flowering">   <span class="icon">🌱</span><span class="label">Soil · Flowering</span></li>
        <li class="step" id="step-soil_fruiting">    <span class="icon">🌱</span><span class="label">Soil · Fruiting</span></li>
        <li class="step" id="step-soil_harvesting">  <span class="icon">🌱</span><span class="label">Soil · Harvesting</span></li>
    </ul>

    <p class="current-label" id="currentLabel">Starting…</p>
</div>

<script>
const es  = new EventSource('/plants/generating/{{ plant.id }}/stream');
const bar = document.getElementById('progressBar');
const lbl = document.getElementById('currentLabel');

es.addEventListener('ping', () => {}); // Verbindungsbestätigung

es.addEventListener('progress', e => {
    const d = JSON.parse(e.data);

    // Mark previous step done
    document.querySelectorAll('.step.active').forEach(el => {
        el.classList.remove('active');
        el.classList.add('done');
        el.querySelector('.icon').textContent = '✓';
    });

    // Mark current step active
    const el = document.getElementById('step-' + d.step);
    if (el) el.classList.add('active');

    bar.style.width = Math.round((d.current / d.total) * 100) + '%';
    lbl.textContent = d.label + '…';
});

es.addEventListener('done', e => {
    const d = JSON.parse(e.data);
    es.close();

    // Mark all remaining active as done
    document.querySelectorAll('.step.active').forEach(el => {
        el.classList.remove('active');
        el.classList.add('done');
        el.querySelector('.icon').textContent = '✓';
    });

    bar.style.width = '100%';
    lbl.textContent = 'Done! Redirecting…';

    setTimeout(() => {
        window.location.href = '/plants/' + d.slug;
    }, 600);
});

es.onerror = () => {
    lbl.textContent = 'Connection lost — please reload.';
    es.close();
};
</script>
{% endblock %}
