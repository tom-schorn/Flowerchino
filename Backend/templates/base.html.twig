<!DOCTYPE html>
<html lang="en" data-theme="vienna">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Flowerchino{% endblock %}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Lora:ital,wght@0,600;1,400&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/build/app.css">
    <style>
        body { font-family: 'Inter', sans-serif; }
        .font-lora { font-family: 'Lora', serif; }
    </style>
    {% block stylesheets %}{% endblock %}
</head>
<body class="bg-base-100 text-base-content min-h-screen">

    <div class="navbar bg-primary text-primary-content px-6 min-h-[60px]">
        <div class="flex-1">
            <a href="/" class="font-lora text-xl text-accent tracking-wide">🌿 Flowerchino</a>
        </div>
        <div class="flex-none gap-3">
            <a href="/plants" class="btn btn-ghost btn-sm text-primary-content/80 hover:text-primary-content">Plants</a>
            <a href="/community" class="btn btn-ghost btn-sm text-primary-content/80 hover:text-primary-content">Community</a>
            {% if app.user %}
                <a href="/profile" class="btn btn-ghost btn-sm text-primary-content/80">{{ app.user.username }}</a>
            {% else %}
                <a href="/login" class="btn btn-ghost btn-sm text-primary-content/80">Sign in</a>
                <a href="/register" class="btn btn-accent btn-sm font-semibold">Join</a>
            {% endif %}
        </div>
    </div>

    {% block body %}{% endblock %}

    {% block javascripts %}{% endblock %}
</body>
</html>
