<!DOCTYPE html>
<html lang="en" data-theme="flowerchino">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Flowerchino{% endblock %}</title>
    <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>🌱</text></svg>">

    {# Tailwind + DaisyUI #}
    <link href="https://cdn.jsdelivr.net/npm/daisyui@4.12.10/dist/full.min.css" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        espresso:   { DEFAULT: '#3d2314', light: '#5c3520', muted: '#a07850' },
                        cappuccino: { DEFAULT: '#c4a882', light: '#e8d5b8', cream: '#f5efe6' },
                    }
                }
            }
        }
    </script>

    {# DaisyUI custom theme #}
    <style>
        [data-theme="flowerchino"] {
            /* Cappuccino palette */
            --p: 25 35% 28%;        /* primary = dark espresso brown */
            --pf: 25 35% 22%;
            --pc: 0 0% 100%;
            --s: 30 30% 45%;        /* secondary = warm caramel */
            --sc: 0 0% 100%;
            --a: 142 28% 35%;       /* accent = muted sage green */
            --ac: 0 0% 100%;
            --n: 25 20% 20%;
            --nc: 0 0% 100%;
            --b1: 30 25% 97%;       /* base = warm cream */
            --b2: 30 20% 92%;       /* slightly darker cream */
            --b3: 30 15% 85%;       /* card borders */
            --bc: 25 25% 18%;       /* text = dark espresso */
            --in: 198 80% 50%;
            --su: 142 50% 40%;
            --wa: 35 92% 51%;
            --er: 0 72% 55%;
        }

        body { background-color: #f5efe6; }

        /* Scrollbar subtle */
        ::-webkit-scrollbar { width: 6px; height: 6px; }
        ::-webkit-scrollbar-track { background: #f0e6d8; }
        ::-webkit-scrollbar-thumb { background: #c4a882; border-radius: 3px; }
    </style>

    {% block stylesheets %}{% endblock %}
</head>
<body class="bg-base-200 min-h-screen">

{# ── Navbar ── #}
<div class="navbar bg-primary text-white shadow-md px-4 lg:px-8">
    <div class="navbar-start">
        <a href="{{ path('plant_index') }}" class="flex items-center gap-2 text-white hover:opacity-80 transition-opacity">
            <span class="text-xl">🌱</span>
            <span class="font-bold text-lg tracking-tight">Flowerchino</span>
        </a>
    </div>
    <div class="navbar-center hidden md:flex">
        <ul class="menu menu-horizontal gap-1 text-sm">
            <li><a href="{{ path('plant_index') }}" class="text-white/80 hover:text-white hover:bg-white/10 rounded-lg">Plants</a></li>
            <li><a href="{{ path('plant_request') }}" class="text-white/80 hover:text-white hover:bg-white/10 rounded-lg">Request</a></li>
        </ul>
    </div>
    <div class="navbar-end">
        <a href="{{ path('plant_request') }}" class="btn btn-sm bg-white/15 hover:bg-white/25 text-white border-0">
            + Request Plant
        </a>
    </div>
</div>

{# ── Content ── #}
<main class="max-w-6xl mx-auto px-4 py-8">
    {% block body %}{% endblock %}
</main>

{% block javascripts %}
    {% block importmap %}{{ importmap('app') }}{% endblock %}
{% endblock %}

</body>
</html>
