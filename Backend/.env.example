APP_ENV=prod
APP_SECRET=change_me_to_a_random_32char_string

# Dev (SQLite)
# DATABASE_URL="sqlite:///%kernel.project_dir%/var/flowerchino.db"

# Prod (MariaDB / MySQL)
DATABASE_URL="mysql://DB_USER:DB_PASSWORD@127.0.0.1:3306/DB_NAME?serverVersion=10.11&charset=utf8mb4"

ANTHROPIC_API_KEY=sk-ant-api03-...

# Lock store (flock = local file, fine for single-server setups)
LOCK_DSN=flock

# CORS — adjust to your frontend domain
CORS_ALLOW_ORIGIN='^https?://(yourdomain\.com)(:[0-9]+)?$'

# Used for absolute URL generation (sitemap, etc.)
DEFAULT_URI=https://yourdomain.com
